# ============================================================
# Control G - Variables de Entorno
# ============================================================
# Copia este archivo como .env y completa los valores
# cp .env.example .env

# ------------------------------------------------------------
# FRONTEND (Vite - accesibles en el browser)
# ------------------------------------------------------------
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=
VITE_APPWRITE_DATABASE_ID=control_g

# ------------------------------------------------------------
# BACKEND / SCRIPTS (server-side, NO exponer en el browser)
# ------------------------------------------------------------
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=

# ------------------------------------------------------------
# IDs de Colecciones (generados por setup-appwrite.mjs)
# ------------------------------------------------------------
# Estos IDs se asignan automáticamente en el script de setup.
# Si usas IDs personalizados, actualiza src/lib/appwrite.ts

